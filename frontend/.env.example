# Copy to .env and adjust. .env is gitignored.

# --- API ---
# Gateway base URL. In prod set to https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:2000

# --- Logging ---
# Level: debug | info | warn | error. Default: debug in dev, info in prod.
VITE_LOG_LEVEL=debug

# Optional collector for warn+error logs. Uses navigator.sendBeacon.
# VITE_LOG_SINK_URL=https://logs.yourdomain.com/ingest
